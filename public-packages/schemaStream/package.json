{
  "name": "schema-stream",
  "version": "3.2.2",
  "author": "Dimitri Kennedy <dimitri@sick.email> (https://hack.dance)",
  "homepage": "https://island.hack.dance",
  "repository": {
    "directory": "public-packages/schemaStream",
    "type": "git",
    "url": "https://github.com/hack-dance/island-ai.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/**"
  ],
  "sideEffects": false,
  "license": "MIT",
  "scripts": {
    "test": "bun test --coverage --verbose",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "TIMING=1 eslint src/**/*.ts* --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "devDependencies": {
    "@openai/agents": "0.13.1",
    "@repo/eslint-config": "workspace:*",
    "@types/eslint": "^8.56.1",
    "@repo/typescript-config": "workspace:*",
    "bun-types": "^1.0.15",
    "eslint": "^8.53.0",
    "ai": "6.0.222",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "zod": "^4.4.3",
    "zod3": "npm:zod@^3.25.0"
  },
  "peerDependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  }
}
