{
  "name": "stream-hooks",
  "version": "4.0.0",
  "author": "Dimitri Kennedy <dimitri@sick.email> (https://hack.dance)",
  "homepage": "https://island.hack.dance",
  "repository": {
    "directory": "public-packages/hooks",
    "type": "git",
    "url": "https://github.com/hack-dance/island-ai.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "llm",
    "structured output",
    "streaming",
    "react",
    "zod"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/**"
  ],
  "sideEffects": false,
  "license": "MIT",
  "scripts": {
    "test": "bun test --coverage --verbose",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "devDependencies": {
    "zod-stream": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^20.10.6",
    "@types/eslint": "^8.56.1",
    "@types/react": "^19.2.17",
    "eslint": "^8.53.0",
    "react": "^19.2.7",
    "typescript": "^5.9.3",
    "tsup": "^8.5.1",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "zod-stream": "^4.0.0",
    "react": "^18.3.0 || ^19.0.0",
    "zod": "^4.0.0"
  }
}
