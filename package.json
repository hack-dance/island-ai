{
  "name": "island-ai",
  "private": true,
  "scripts": {
    "build": "turbo run build --concurrency=11",
    "dev": "turbo dev --concurrency=11",
    "docs": "turbo dev --filter=docs",
    "lint": "turbo lint --concurrency=11",
    "type-check": "turbo type-check --concurrency=11",
    "test:packed": "bash tests/packed-consumer/verify.sh",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:write": "prettier --write \"**/*.{js,json,jsx,ts,tsx}\"",
    "start": "turbo run start --filter=docs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "turbo run build --filter='./public-packages/*' && changeset publish",
    "sync-ls": "syncpack lint --specifier-types exact,range",
    "sync-up": "syncpack fix --specifier-types exact,range"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "^1.3.14",
    "husky": "^8.0.3",
    "prettier": "^3.9.5",
    "syncpack": "^15.3.2",
    "turbo": "^2.10.4"
  },
  "overrides": {
    "@babel/helpers": "^7.29.7",
    "@babel/runtime": "^7.29.7",
    "braces": "^3.0.3",
    "cross-spawn": "^7.0.6",
    "diff": "^5.2.2",
    "engine.io": "^6.6.9",
    "estree-util-value-to-estree": "^3.5.0",
    "flatted": "^3.4.2",
    "form-data": "^4.0.6",
    "lodash": "^4.18.1",
    "micromatch": "^4.0.8",
    "nanoid": "^3.3.15",
    "postcss": "^8.5.16",
    "socket.io-adapter": "^2.5.8",
    "socket.io-parser": "^4.2.6",
    "yaml": "^2.8.3"
  },
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=22"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*",
    "public-packages/*"
  ]
}
